+package com.privatevpn.app.ui.screens
+
+import androidx.lifecycle.ViewModel
+import androidx.lifecycle.viewModelScope
+import com.privatevpn.app.core.model.VpnProfile
+import com.privatevpn.app.core.repository.ProfileRepository
+import com.privatevpn.app.importer.XrayConfigImporter
+import com.privatevpn.app.scanner.ScannerBackendClient
+import com.privatevpn.app.scanner.ScannerReport
+import com.privatevpn.app.vpn.engine.VpnEngine
+import com.privatevpn.app.vpn.leakguard.LeakGuard
+import dagger.hilt.android.lifecycle.HiltViewModel
+import javax.inject.Inject
+import kotlinx.coroutines.flow.MutableStateFlow
+import kotlinx.coroutines.flow.StateFlow
+import kotlinx.coroutines.flow.asStateFlow
+import kotlinx.coroutines.flow.stateIn
+import kotlinx.coroutines.flow.SharingStarted
+import kotlinx.coroutines.launch
+
+@HiltViewModel
+class VpnViewModel @Inject constructor(
+    repository: ProfileRepository,
+    private val importer: XrayConfigImporter,
+    private val vpnEngine: VpnEngine,
+    private val leakGuard: LeakGuard,
+    private val scannerBackendClient: ScannerBackendClient
+) : ViewModel() {
+
+    val profiles = repository.observeProfiles().stateIn(viewModelScope, SharingStarted.WhileSubscribed(5000), emptyList())
+    private val _status = MutableStateFlow("Отключено")
+    val status: StateFlow<String> = _status.asStateFlow()
+
+    private val _logs = MutableStateFlow(listOf("Журнал инициализирован"))
+    val logs: StateFlow<List<String>> = _logs.asStateFlow()
+
+    private val _scanner = MutableStateFlow<ScannerReport?>(null)
+    val scanner: StateFlow<ScannerReport?> = _scanner.asStateFlow()
+
+    private val _securityIssues = MutableStateFlow<List<String>>(emptyList())
+    val securityIssues: StateFlow<List<String>> = _securityIssues.asStateFlow()
+
+    private val repo = repository
+
+    fun importRaw(raw: String) = viewModelScope.launch {
+        val result = importer.import(raw)
+        repo.save(result.profile)
+        appendLog("Импортирован профиль: ${result.profile.name}")
+        result.warning?.let { appendLog(it) }
+    }
+
+    fun connect(profile: VpnProfile?) = viewModelScope.launch {
+        if (profile == null) {
+            appendLog("Нет выбранного профиля")
+            return@launch
+        }
+        val issues = leakGuard.validate(profile, dnsInTunnel = true, bypassEnabled = false, allowlistCount = 1, unsafeSocks = false)
+        _securityIssues.value = issues
+        if (issues.isNotEmpty()) {
+            _status.value = "Проблемы безопасности"
+            appendLog("LeakGuard: ${issues.joinToString()}")
+            return@launch
+        }
+        _status.value = "Подключение..."
+        vpnEngine.connect(profile)
+            .onSuccess {
+                _status.value = "Подключено"
+                appendLog("VPN подключён: ${profile.host}:${profile.port}")
+            }
+            .onFailure {
+                _status.value = "Ошибка"
+                appendLog("Ошибка подключения: ${it.message}")
+            }
+    }
+
+    fun disconnect() = viewModelScope.launch {
+        vpnEngine.disconnect()
+        _status.value = "Отключено"
+        appendLog("VPN отключён")
+    }
+
+    fun runScannerLab() = viewModelScope.launch {
+        _scanner.value = ScannerReport(
+            networkSummary = "Активная сеть: VPN",
+            capabilities = "TRANSPORT_VPN, NOT_METERED",
+            linkProperties = "dns=1.1.1.1, routes=0.0.0.0/0",
+            externalIp = scannerBackendClient.ip(),
+            geo = scannerBackendClient.geo(),
+            asn = scannerBackendClient.asn(),
+            localhostSocksOpen = false
+        )
+        appendLog("Лаборатория сканера: проверка завершена")
+    }
+
+    private fun appendLog(message: String) {
+        _logs.value = listOf("• $message") + _logs.value
+    }
+}
