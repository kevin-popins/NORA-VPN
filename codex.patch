+package com.privatevpn.app.navigation
+
+import androidx.compose.runtime.Composable
+import androidx.hilt.navigation.compose.hiltViewModel
+import androidx.navigation.compose.NavHost
+import androidx.navigation.compose.composable
+import androidx.navigation.compose.rememberNavController
+import com.privatevpn.app.ui.screens.AddProfileScreen
+import com.privatevpn.app.ui.screens.AppsScreen
+import com.privatevpn.app.ui.screens.DnsSettingsScreen
+import com.privatevpn.app.ui.screens.HomeScreen
+import com.privatevpn.app.ui.screens.LogsScreen
+import com.privatevpn.app.ui.screens.OnboardingScreen
+import com.privatevpn.app.ui.screens.ProfilesScreen
+import com.privatevpn.app.ui.screens.ScannerLabScreen
+import com.privatevpn.app.ui.screens.SecurityCheckScreen
+import com.privatevpn.app.ui.screens.SessionScreen
+import com.privatevpn.app.ui.screens.SettingsScreen
+import com.privatevpn.app.ui.screens.SplashScreen
+import com.privatevpn.app.ui.screens.VpnViewModel
+
+@Composable
+fun AppNavHost(viewModel: VpnViewModel = hiltViewModel()) {
+    val navController = rememberNavController()
+
+    NavHost(navController = navController, startDestination = Route.Splash.path) {
+        composable(Route.Splash.path) { SplashScreen { navController.navigate(Route.Onboarding.path) } }
+        composable(Route.Onboarding.path) { OnboardingScreen { navController.navigate(Route.Home.path) } }
+        composable(Route.Home.path) { HomeScreen(navController, viewModel) }
+        composable(Route.Profiles.path) { ProfilesScreen(navController, viewModel) }
+        composable(Route.AddProfile.path) { AddProfileScreen(navController, viewModel) }
+        composable(Route.Apps.path) { AppsScreen(navController, viewModel) }
+        composable(Route.PrivateSession.path) { SessionScreen(navController, viewModel, isPrivate = true) }
+        composable(Route.ActiveSession.path) { SessionScreen(navController, viewModel, isPrivate = false) }
+        composable(Route.SecurityCheck.path) { SecurityCheckScreen(navController, viewModel) }
+        composable(Route.ScannerLab.path) { ScannerLabScreen(navController, viewModel) }
+        composable(Route.Logs.path) { LogsScreen(navController, viewModel) }
+        composable(Route.Dns.path) { DnsSettingsScreen(navController, viewModel) }
+        composable(Route.Settings.path) { SettingsScreen(navController, viewModel) }
+    }
+}
