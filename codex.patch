+import kotlinx.coroutines.flow.Flow
+import kotlinx.coroutines.flow.map
+import javax.inject.Inject
+
+class AppSettingsStore @Inject constructor(private val dataStore: DataStore<Preferences>) {
+    private val privateModeKey = booleanPreferencesKey("private_mode")
+
+    val privateModeEnabled: Flow<Boolean> = dataStore.data.map { it[privateModeKey] ?: false }
