+package com.privatevpn.app.vpn.service
+
+import android.app.Service
+import android.content.Intent
+import android.net.VpnService
+import android.os.IBinder
+
+class PrivateVpnService : VpnService() {
+    private var tun: ParcelFileDescriptorHolder? = null
+
+    override fun onStartCommand(intent: Intent?, flags: Int, startId: Int): Int {
+        val builder = Builder()
+            .setSession("Приватная сессия VPN")
+            .addAddress("10.31.0.2", 24)
+            .addRoute("0.0.0.0", 0)
+            .addDnsServer("1.1.1.1")
+            .addDnsServer("8.8.8.8")
+
+        tun = builder.establish()?.let { ParcelFileDescriptorHolder(it.detachFd()) }
+        return Service.START_STICKY
+    }
+
+    override fun onBind(intent: Intent): IBinder? = super.onBind(intent)
+
+    override fun onDestroy() {
+        tun?.close()
+        tun = null
+        super.onDestroy()
+    }
+}
+
+private class ParcelFileDescriptorHolder(private val fd: Int) {
+    fun close() {
+        try {
+            android.system.Os.close(fd)
+        } catch (_: Exception) {
+        }
+    }
+}
