+package com.privatevpn.app.vpn.leakguard
+
+import com.privatevpn.app.core.model.VpnProfile
+import javax.inject.Inject
+
+class LeakGuard @Inject constructor() {
+    fun validate(
+        profile: VpnProfile,
+        dnsInTunnel: Boolean,
+        bypassEnabled: Boolean,
+        allowlistCount: Int,
+        unsafeSocks: Boolean
+    ): List<String> {
+        val issues = mutableListOf<String>()
+        if (bypassEnabled) issues += "Обнаружен bypass: для приватной сессии отключите обход VPN"
+        if (!dnsInTunnel) issues += "DNS не задан внутри туннеля"
+        if (allowlistCount == 0) issues += "Список доверенных приложений пуст"
+        if (unsafeSocks) issues += "Локальный SOCKS небезопасен: включите 127.0.0.1 + авторизацию"
+        if (profile.host.isBlank()) issues += "В профиле отсутствует адрес сервера"
+        return issues
+    }
+}
