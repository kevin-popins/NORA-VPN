@@ -0,0 +1,63 @@
+package com.privatevpn.app.importer
+
+import android.net.Uri
+import com.privatevpn.app.core.model.VpnProfile
+import kotlinx.serialization.json.Json
+import kotlinx.serialization.json.jsonArray
+import kotlinx.serialization.json.jsonObject
+import kotlinx.serialization.json.jsonPrimitive
+import javax.inject.Inject
+
+class XrayConfigImporter @Inject constructor() {
+    private val json = Json { ignoreUnknownKeys = true }
+
+    fun import(raw: String): ConfigImportResult {
+        return when {
+            raw.startsWith("vless://") || raw.startsWith("vmess://") || raw.startsWith("trojan://") -> importUri(raw)
+            raw.trim().startsWith("{") -> importJson(raw)
+            else -> ConfigImportResult(
+                VpnProfile(name = "Неизвестный импорт", type = "unknown", host = "", port = 0, rawConfig = raw, importedPartially = true),
+                "Формат не распознан, профиль сохранён как сырой"
+            )
+        }
+    }
+
+    private fun importUri(raw: String): ConfigImportResult {
+        val uri = Uri.parse(raw)
+        return ConfigImportResult(
+            profile = VpnProfile(
+                name = uri.fragment ?: "Импорт ${uri.scheme}",
+                type = uri.scheme ?: "unknown",
+                host = uri.host.orEmpty(),
+                port = if (uri.port > 0) uri.port else 443,
+                rawConfig = raw
+            )
+        )
+    }
+
+    private fun importJson(raw: String): ConfigImportResult {
+        val obj = json.parseToJsonElement(raw).jsonObject
+        val outbounds = obj["outbounds"]?.jsonArray
+        val first = outbounds?.firstOrNull()?.jsonObject
+        val settings = first?.get("settings")?.jsonObject
+        val vnext = settings?.get("vnext")?.jsonArray?.firstOrNull()?.jsonObject
+        val host = vnext?.get("address")?.jsonPrimitive?.contentOrNull.orEmpty()
+        val port = vnext?.get("port")?.jsonPrimitive?.intOrNull ?: 443
+        val security = first?.get("streamSettings")?.jsonObject
+            ?.get("security")?.jsonPrimitive?.contentOrNull ?: "none"
+
+        val partial = obj.keys.any { it !in listOf("inbounds", "outbounds", "log", "routing", "dns") }
+        return ConfigImportResult(
+            profile = VpnProfile(
+                name = "Xray JSON (${if (security == "reality") "REALITY" else "общий"})",
+                type = "xray-json",
+                host = host,
+                port = port,
+                rawConfig = raw,
+                importedPartially = partial,
+                importNote = if (partial) "Часть секций не используется в MVP" else ""
+            ),
+            warning = if (partial) "Импорт выполнен частично: неизвестные секции пропущены" else null
+        )
+    }
+}
